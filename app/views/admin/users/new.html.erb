<% content_for :stylesheet do %>
    <%#= stylesheet_link_tag 'edit' %>
<% end %>
<!-- BEGIN NEW PAGE -->
<div class="row">
  <div class="col">
    <%= link_to raw("<div class='btn p-0 text-black'><span class=\"bi bi-chevron-left\"></span> "+translate_view_shared("back")+"</div>"), instances_index_path %>
    <div class="d-flex justify-content-between mt-2">
      <div>
        <h3><%= translate_view_shared('new_title', model_name: model_singular_translation) %></h3>
      </div>
      <div>
        <a href=<%= "#{instances_index_path}"%> class="btn btn-outline-secondary"><%=translate_view_shared("cancel")%></a>
        <button type="submit" @click="submitForm('<%= 'new_' + @instance.class.name.underscore.sub("/", "_") %>')" class="btn btn-primary"><%= translate_view_shared("save") %></button>
      </div>
    </div>
  </div>
  <%= form_for @instance, url: instance_create_path, multipart: true, method: 'post', html: { novalidate: true} do |f| %>
    <%= render partial: 'form_errors' %>
    <div class="row">
        <div class="mb-3">
          <%= f.label :email_address, attribute_translation(model_singular_name_to_translate(@instance), :email_address), class: 'form-label' %>
          <%= f.text_field :email_address, class: 'form-control', id: "#{model_field_id(@instance, :email_address)}" %>
        </div> 
        <div class="mb-3">
          <%= f.label :password, attribute_translation(model_singular_name_to_translate(@instance), :password), class: 'form-label' %>
          <%= f.text_field :password, class: 'form-control', id: "#{model_field_id(@instance, :password)}" %>
        </div> 
        
    </div>
    <%= f.submit %>
  <% end %>
</div>
<!-- END NEW PAGE -->